// Write a program which creates a structure Student which must have the attribute Avg Marks with 3 more attributes sort the list of the student in descending order using Bubble sort.

#include <stdio.h>

struct Student {
    char name[50];
    int roll;
    float marks[3];
    float avg;
};

int main() {
    struct Student s[100], temp;
    int n, i, j;

    printf("Enter number of students: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("\nEnter details of student %d:\n", i + 1);

        printf("Name: ");
        scanf("%s", s[i].name);

        printf("Roll number: ");
        scanf("%d", &s[i].roll);

        printf("Enter 3 subject marks: ");
        scanf("%f %f %f", &s[i].marks[0], &s[i].marks[1], &s[i].marks[2]);

        s[i].avg = (s[i].marks[0] + s[i].marks[1] + s[i].marks[2]) / 3.0;
    }

    for(i = 0; i < n - 1; i++) {
        for(j = 0; j < n - i - 1; j++) {
            if(s[j].avg < s[j + 1].avg) { 
                temp = s[j];
                s[j] = s[j + 1];
                s[j + 1] = temp;
            }
        }
    }

    printf("\nStudents sorted in Descending order of Average Marks:\n");
    for(i = 0; i < n; i++) {
        printf("\nName: %s", s[i].name);
        printf("\nRoll No: %d", s[i].roll);
        printf("\nAverage Marks: %.2f\n", s[i].avg);
    }

    return 0;
}

